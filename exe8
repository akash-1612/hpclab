#include<stdio.h>
#include<stdlib.h>
#include<omp.h>
#include<time.h>
int main()
{
        int n;
        printf("Enter the no of array elements:");
        scanf("%d",&n);
        int *a=(int*)malloc(n*sizeof(int));
        int *b=(int*)malloc(n*sizeof(int));
        int *c=(int*)malloc(n*sizeof(int));
        for(int i=0;i<n;i++)
        {
                a[i]=rand()%10;
                b[i]=rand()%10;
        }
        printf("Matrix A:\n");
        for(int i=0;i<n;i++)
        {
                printf("%d ",a[i]);
        }
        printf("\nMatrix B:\n");
        for(int i=0;i<n;i++)
        {
                printf("%d ",b[i]);
        }
#pragma omp parallel for
        for(int i=0;i<n;i++)
        {
                c[i]=a[i]+b[i];
        }
        printf("\nsum of two large arrays:");
        for(int i=0;i<n;i++)
        {
                printf("%d ",c[i]);
        }
}


