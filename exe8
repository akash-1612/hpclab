int main()
{
        int n,c;
        printf("Enter the no of array elements:");
        scanf("%d",&n);
        int *a=(int*)malloc(n*sizeof(int));
        for(int i=0;i<n;i++)
        {
                a[i]=rand()%10;
        }
        printf("Array:\n");
        for(int i=0;i<n;i++)
        {
                printf("%d ",a[i]);
        }
        printf("\nEnter the constant vaule added to the array:");
        scanf("%d",&c);
#pragma omp parallel for
        for(int i=0;i<n;i++)
        {
                a[i]+=c;
        }
        printf("\nArray element after increment by c:\n");
        for(int i=0;i<n;i++)
        {
                printf("%d ",a[i]);
        }
}

