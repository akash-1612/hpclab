}

double calc_determinant(int m, int *a) {
    if (m == 1) {
        return a[0];
    }
    if (m == 2) {
        return a[0] * a[3] - a[1] * a[2];
    }
    double det = 0.0;
    int j,sub_i,sub_j;
    for (j = 0; j < m; j++) {
